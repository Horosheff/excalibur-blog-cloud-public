name: Cloud preflight

on:
  pull_request:
  push:
    branches:
      - main

jobs:
  preflight:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: python -m pip install -r requirements.txt

      - name: Compile Python scripts
        run: python -m compileall scripts

      - name: Run doctor
        run: python scripts/excalibur_blog_doctor.py

      - name: Check topic gate
        run: python scripts/excalibur_blog_utility_gate.py --topic-id B01
