# Cursor Cloud / self-hosted worker
CURSOR_API_KEY=

# Public site
WP_SITE_URL=
WP_ADMIN_URL=
PUBLIC_SITE_URL=

# Excalibur BLOG publish
EXCALIBUR_BLOG_ALLOW_PUBLISH=no
EXCALIBUR_TOPIC_ID=
EXCALIBUR_PROJECT_ROOT=

# SSH publish
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_PASS=
# SSH_PASSWORD is also supported as an alias for Cloud providers that use this name.
SSH_PASSWORD=
SSH_ROOT=/

# MCP tokens via env interpolation in mcp.json — never commit real values
# MCP_KV_TOKEN=
